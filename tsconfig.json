{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "allowJs": true,
    "incremental": true,
    "tsBuildInfoFile": "./tsconfig.full.tsbuildinfo",
    "jsx": "react-jsx",
    "paths": {
      "@ant/claude-for-chrome-mcp": [
        "./stubs/ant-claude-for-chrome-mcp.ts"
      ],
      "color-diff-napi": [
        "./stubs/color-diff-napi.ts"
      ],
      "src/*": [
        "./src/*"
      ]
    },
    "types": [
      "bun-types"
    ]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "tests/**/*.ts",
    "preload.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
