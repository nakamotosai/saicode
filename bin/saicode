#!/usr/bin/env bun

import { spawn } from 'child_process'
import { dirname, join } from 'path'
import { fileURLToPath } from 'url'

const rootDir = dirname(dirname(fileURLToPath(import.meta.url)))
const entrypoint =
  process.env.SAICODE_FORCE_RECOVERY_CLI === '1'
    ? join(rootDir, 'src', 'localRecoveryCli.ts')
    : join(rootDir, 'src', 'entrypoints', 'cli.tsx')

const child = spawn(
  process.execPath,
  ['--env-file=.env', entrypoint, ...process.argv.slice(2)],
  {
    cwd: rootDir,
    env: process.env,
    stdio: 'inherit',
  },
)

child.on('exit', code => {
  process.exit(code ?? 0)
})
